# Anthropic API key — used by enrich.py for Sonnet enrichment
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for enrichment
ANTHROPIC_MODEL=claude-sonnet-4-6

# Qdrant connection (matches docker-compose.yml)
QDRANT_URL=http://localhost:6333

# Where docs live (relative to repo root). Comma-separated list — every *.md
# under any of these is indexed. Use DOCS_ROOTS for new setups; DOCS_ROOT is
# kept as a fallback for single-path setups.
DOCS_ROOTS=docs/project-data,docs/adr

# Where intermediate artifacts go (relative to this folder)
DATA_DIR=data

# Qdrant collection names
COLLECTION_DOCUMENTS=proshop_docs_documents
COLLECTION_CHUNKS=proshop_docs_chunks

# Splitter targets (tokens)
CHUNK_TARGET_TOKENS=400
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=80

# Enrichment batch size (chunks per Anthropic call)
ENRICH_BATCH_SIZE=4
ENRICH_PARALLELISM=1